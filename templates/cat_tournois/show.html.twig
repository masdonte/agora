{% extends 'base.html.twig' %}

{% block title %}CatTournois
{% endblock %}

{% block body %}
	<!-- page start -->
	<div class="col-sm-8">
		<section class="panel">
			<div class="chat-room-head">
				<h3>
					<i class="fa fa-angle-right"></i>
					Détails catégorie de tournois
				</h3>
			</div>
			<div class="panel-body">
				<h1>Catégorie Tournois</h1>
				<table class="table table-striped table-advance table-hover">
					<tbody>
						<tr>
							<th class="tableau-entete">
								<i class="fa fa-bullhorn"></i>
								Identif
							</th>
							<td>{{ cat_tournoi.id }}</td>
						</tr>
						<tr>
							<th class="tableau-entete">
								<i class="fa fa-bookmark"></i>
								Libellé
							</th>
							<td>{{ cat_tournoi.libelle }}</td>
						</tr>
					</tbody>
				</table>
				<a href="{{ path('app_cat_tournois_index') }}">
					<button class="btn btn-primary btn-xs">
						<i class="fa fa-share"></i>
					</button>
				</a>
				<a href="{{ path('app_cat_tournois_edit', {'id': cat_tournoi.id}) }}">
					<button class="btn btn-primary btn-xs">
						<i class="fa fa-pencil"></i>
					</button>
				</a>
				{{ include('cat_tournois/_delete_form.html.twig') }}
			</div>
			<!-- fin div panel-body-->
		</section>

		{# Section Reconnaissance liée à la catégorie de tournois #}
		<section class="panel">
			<div class="chat-room-head">
				<h3>
					<i class="fa fa-star"></i>
					Reconnaissances liées
				</h3>
			</div>
			<div class="panel-body">
				{% if cat_tournoi.reconnaissances|length > 0 %}
					<table class="table table-striped table-advance table-hover">
						<thead>
							<tr>
								<th>Nom</th>
								<th>Niveau</th>
								<th>Actions</th>
							</tr>
						</thead>
						<tbody>
							{% for reconnaissance in cat_tournoi.reconnaissances %}
								<tr>
									<td>{{ reconnaissance.Nom }}</td>
									<td>{{ reconnaissance.Niveau }}</td>
									<td>
										<a href="{{ path('app_reconnaissance_show', {'id': reconnaissance.id}) }}">Voir</a>
										{% if is_granted('ROLE_ADMIN') %}
											<a href="{{ path('app_reconnaissance_edit', {'id': reconnaissance.id}) }}">Modifier</a>
											{{ include('reconnaissance/_delete_form.html.twig') }}
										{% endif %}
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				{% else %}
					<p>Aucune reconnaissance liée pour cette catégorie.</p>
				{% endif %}
			</div>
		</section>
		<!-- fin section reconnaissance-->
		<!-- fin section tournois-->
	</div>
	<!--fin div col-sm-8-->
{% endblock %}
